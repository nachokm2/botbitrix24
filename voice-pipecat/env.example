# Servicio de voz Pipecat — variables de entorno

# URL pública de ESTE servicio (con WSS). Ej. Railway/Fly o ngrok en pruebas.
PUBLIC_URL=https://tu-servicio-pipecat.up.railway.app
PORT=7860

# Backend Node del bot (catálogo + CRM). Mismo dominio del PoC actual.
BACKEND_BASE=https://botbitrix24-production.up.railway.app
VOICE_SECRET=el-mismo-VAPI_SECRET-del-backend

# LLM (Claude)
ANTHROPIC_API_KEY=
VOICE_MODEL=claude-3-5-haiku-20241022

# STT
DEEPGRAM_API_KEY=

# TTS (Azure, voz es-CL)
AZURE_SPEECH_API_KEY=
AZURE_SPEECH_REGION=eastus

# Telefonía (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+56...
