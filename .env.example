# ---- Servidor ----
PORT=3000
# URL pública HTTPS del app (Railway o túnel). SIN slash final.
# Ej: https://poc-agente-bitrix24-production.up.railway.app
BASE_URL=

# ---- Anthropic (BYOK) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_CLASSIFIER=claude-haiku-4-5

# ---- Bot ----
BOT_CODE=poc_agente_postgrados

# ---- Bitrix OAuth (renovación del access_token) ----
# Del registro de la app local en el portal (ID y Clave de la aplicación).
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=

# ---- Opcional: smoke REST sin OAuth ----
# Webhook entrante de Bitrix24 (Aplicaciones > Webhooks > Webhook entrante).
# Solo para `npm run smoke:bitrix` rápido; el bot en sí usa OAuth.
# Ej: https://tu-portal.bitrix24.cl/rest/1/abcdef123456
BITRIX_WEBHOOK_URL=
