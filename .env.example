# ---- Servidor ----
PORT=3000
# URL pública HTTPS del app (Railway o túnel). SIN slash final.
# Ej: https://poc-agente-bitrix24-production.up.railway.app
BASE_URL=

# ---- Anthropic (BYOK) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_CLASSIFIER=claude-haiku-4-5

# ---- Bot ----
BOT_CODE=poc_agente_postgrados

# ---- Bitrix OAuth (renovación del access_token) ----
# Del registro de la app local en el portal (ID y Clave de la aplicación).
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
# Token de aplicación que Bitrix envía en cada evento/instalación (verifica el origen de los webhooks).
# Se captura solo en la instalación (se persiste), pero fijarlo aquí cierra la validación por completo.
BITRIX_APPLICATION_TOKEN=

# ---- Endurecimiento (Seguridad) ----
# Con NODE_ENV=production se activa el "fail-closed": los secretos pasan a ser OBLIGATORIOS.
NODE_ENV=
# Secreto del servidor de voz (Vapi/Pipecat): protege /vapi/events, /voice/* y /voice/outbound.
VAPI_SECRET=
# Token para los paneles embebidos y sus APIs (/app, /calls, /metrics/summary, /calls/data, /stats, /debug/config).
# El placement propaga este token en la URL (?k=). Tras definirlo, re-enlaza: /setup/bind-dashboard y /setup/bind-calls.
DASHBOARD_TOKEN=
# Token para las utilidades administrativas (/setup/*).
ADMIN_TOKEN=
# Rate limiting por IP (peticiones/minuto): global y estricto (eventos del bot + llamadas salientes).
RATE_LIMIT_MAX=600
RATE_LIMIT_STRICT=240
# Cliente Anthropic: timeout por request (ms) y reintentos.
ANTHROPIC_TIMEOUT_MS=45000
ANTHROPIC_MAX_RETRIES=2
# Tamaño del pool de Postgres.
PGPOOL_MAX=10
# Cifrado de tokens OAuth en reposo (AES-256-GCM). 32 bytes en hex (64 caracteres). Genera: openssl rand -hex 32
# Si se deja vacío, los tokens se guardan en claro (los ya guardados se migran solos al definirla).
TOKEN_ENC_KEY=
# Backpressure: máximo de turnos del bot procesados en paralelo por instancia.
MAX_CONCURRENT_TURNS=8
# Retención de auditoría: borra audit_log más antiguo que N días (0 = desactivado).
AUDIT_RETENTION_DAYS=0
# Redacción de PII en logs y auditoría (email/teléfono). off para desactivar (solo debug local).
LOG_REDACT=on

# ---- Opcional: smoke REST sin OAuth ----
# Webhook entrante de Bitrix24 (Aplicaciones > Webhooks > Webhook entrante).
# Solo para `npm run smoke:bitrix` rápido; el bot en sí usa OAuth.
# Ej: https://tu-portal.bitrix24.cl/rest/1/abcdef123456
BITRIX_WEBHOOK_URL=

# ---- Persistencia / Observabilidad (opcionales; si faltan, se usa memoria/no-op) ----
# En Railway: agrega los plugins "Redis" y "Postgres" → definen REDIS_URL y DATABASE_URL solos.
REDIS_URL=
DATABASE_URL=
# Postgres externo (no el interno de Railway) suele requerir SSL:
PGSSL=false

# ---- Lead Scoring (opcional) ----
# Si creas campos personalizados en el CRM para guardar el scoring, pon aquí sus códigos
# (ej. UF_CRM_1700000000). Si los dejas vacíos, el scoring solo queda como nota en el timeline.
BITRIX_UF_SCORE=
BITRIX_UF_INTENT=
BITRIX_UF_SENTIMENT=

# Mover la etapa del deal según el score, por embudo (multi-flujo). Mapa JSON categoryId -> {alto,medio}.
# Ej (C1=Diplomados, C3=Magísteres):
# {"1":{"alto":"C1:PREPARATION","medio":"C1:UC_JARL1O"},"3":{"alto":"C3:PREPAYMENT_INVOICE","medio":"C3:PREPARATION"}}
BITRIX_STAGE_MAP=
# (Legacy, un solo embudo; usa BITRIX_STAGE_MAP en su lugar):
BITRIX_STAGE_SCORE_ALTO=
BITRIX_STAGE_SCORE_MEDIO=
# Auto-escalar a un asesor si el score alcanza este umbral (0 = desactivado):
SCORE_ESCALAR=80

